# יצירת פרויקט Expo אם הריפו עדיין ריק
if [ ! -f package.json ]; then
  TEMP_DIR="$(mktemp -d)"

  npx --yes create-expo-app@latest "$TEMP_DIR/alfajorsa" \
    --template blank-typescript

  rm -rf "$TEMP_DIR/alfajorsa/.git"
  cp -a "$TEMP_DIR/alfajorsa/." .
  rm -rf "$TEMP_DIR"
fi

# הגדרות בסיסיות
npm pkg set name="alfajorsa-app"
npm pkg set private=true
npm pkg set scripts.typecheck="tsc --noEmit"

