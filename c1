import React, { useMemo, useState } from 'react';
import {
  Alert,
  Linking,
  SafeAreaView,
  ScrollView,
  StatusBar,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';

type Flavor = {
  id: string;
  name: string;
  spanishName: string;
  description: string;
  price: number;
  accent: string;
};

const WHATSAPP_NUMBER = '972500000000';
// החלף במספר שלך ללא +, רווחים או מקפים.
// לדוגמה: 972501234567

const flavors: Flavor[] = [
  {
    id: 'classic',
    name: 'קלאסי שוקולד',
    spanishName: 'Clásico',
    description: 'ריבת חלב ארגנטינאית וציפוי שוקולד עשיר.',
    price: 16,
    accent: '#6B3527',
  },
  {
    id: 'white',
    name: 'שוקולד לבן',
    spanishName: 'Chocolate Blanco',
    description: 'ריבת חלב וציפוי שוקולד לבן עדין.',
    price: 16,
    accent: '#C8A96B',
  },
  {
    id: 'pistachio',
    name: 'פיסטוק',
    spanishName: 'Pistacho',
    description: 'קרם פיסטוק, ריבת חלב ושוקולד איכותי.',
    price: 18,
    accent: '#65704A',
  },
  {
    id: 'coffee',
    name: 'קפה אספרסו',
    spanishName: 'Café Espresso',
    description: 'ריבת חלב עם טעמי קפה עמוקים.',
    price: 17,
    accent: '#493126',
  },
  {
    id: 'lemon',
    name: 'לימון',
    spanishName: 'Limón',
    description: 'קרם לימון רענן עם מתיקות מאוזנת.',
    price: 17,
    accent: '#A58A35',
  },
  {
    id: 'berries',
    name: 'פירות יער',
    spanishName: 'Frutos Rojos',
    description: 'מילוי פירות יער וריבת חלב קטיפתית.',
    price: 18,
    accent: '#7A3444',
  },
  {
    id: 'coconut',
    name: 'קוקוס',
    spanishName: 'Coco',
    description: 'קוקוס עדין, ריבת חלב ושוקולד לבן.',
    price: 17,
    accent: '#9B8568',
  },
  {
    id: 'dark',
    name: 'שוקולד מריר',
    spanishName: 'Chocolate Intenso',
    description: 'קקאו עמוק וציפוי שוקולד מריר.',
    price: 18,
    accent: '#2F2926',
  },
];

export default function App() {
  const [cart, setCart] = useState<Record<string, number>>({});

  const totalItems = useMemo(
    () => Object.values(cart).reduce((sum, amount) => sum + amount, 0),
    [cart],
  );

  const totalPrice = useMemo(
    () =>
      flavors.reduce(
        (sum, flavor) => sum + (cart[flavor.id] ?? 0) * flavor.price,
        0,
      ),
    [cart],
  );

  const addToCart = (id: string) => {
    setCart((current) => ({
      ...current,
      [id]: (current[id] ?? 0) + 1,
    }));
  };

  const removeFromCart = (id: string) => {
    setCart((current) => {
      const nextAmount = Math.max((current[id] ?? 0) - 1, 0);

      return {
        ...current,
        [id]: nextAmount,
      };
    });
  };

  const sendWhatsAppOrder = async () => {
    if (totalItems === 0) {
      Alert.alert('הסל ריק', 'יש להוסיף לפחות אלפחור אחד להזמנה.');
      return;
    }

    const orderLines = flavors
      .filter((flavor) => (cart[flavor.id] ?? 0) > 0)
      .map(
        (flavor) =>
          `• ${flavor.name}: ${cart[flavor.id]} יחידות – ₪${
            flavor.price * cart[flavor.id]
          }`,
      )
      .join('\n');

    const message = [
      'שלום ALFAJORSA 👋',
      'אשמח לבצע הזמנה:',
      '',
      orderLines,
      '',
      `סה״כ פריטים: ${totalItems}`,
      `סה״כ לתשלום: ₪${totalPrice}`,
      '',
      'שם:',
      'כתובת:',
      'טלפון:',
    ].join('\n');

    const url =
      `https://wa.me/${WHATSAPP_NUMBER}` +
      `?text=${encodeURIComponent(message)}`;

    try {
      await Linking.openURL(url);
    } catch {
      Alert.alert(
        'לא ניתן לפתוח WhatsApp',
        'יש לבדוק שמספר ה־WhatsApp בקוד תקין.',
      );
    }
  };

  return (
    <SafeAreaView style={styles.safeArea}>
      <StatusBar barStyle="dark-content" backgroundColor="#F6F0E4" />

      <ScrollView
        contentContainerStyle={styles.page}
        showsVerticalScrollIndicator={false}
      >
        <View style={styles.hero}>
          <View style={styles.monogram}>
            <Text style={styles.monogramText}>Af.</Text>
          </View>

          <Text style={styles.brand}>ALFAJORSA</Text>
          <Text style={styles.subtitle}>טעם ארגנטינאי אמיתי בישראל</Text>

          <View style={styles.goldLine} />

          <Text style={styles.intro}>
            אלפחורס בעבודת יד, עם ריבת חלב עשירה, חומרי גלם איכותיים
            וטעמים בהשראת ארגנטינה.
          </Text>
        </View>

        <View style={styles.sectionHeader}>
          <Text style={styles.sectionTitle}>שמונת הטעמים שלנו</Text>
          <Text style={styles.sectionCaption}>
            בחרו טעמים והוסיפו להזמנה
          </Text>
        </View>

        <View style={styles.grid}>
          {flavors.map((flavor) => {
            const amount = cart[flavor.id] ?? 0;

            return (
              <View key={flavor.id} style={styles.card}>
                <View
                  style={[
                    styles.flavorStripe,
                    { backgroundColor: flavor.accent },
                  ]}
                />

                <Text style={styles.flavorSpanish}>
                  {flavor.spanishName}
                </Text>

                <Text style={styles.flavorName}>{flavor.name}</Text>
                <Text style={styles.description}>
                  {flavor.description}
                </Text>

                <View style={styles.cardBottom}>
                  <Text style={styles.price}>₪{flavor.price}</Text>

                  {amount === 0 ? (
                    <TouchableOpacity
                      style={styles.addButton}
                      activeOpacity={0.8}
                      onPress={() => addToCart(flavor.id)}
                    >
                      <Text style={styles.addButtonText}>הוספה</Text>
                    </TouchableOpacity>
                  ) : (
                    <View style={styles.quantity}>
                      <TouchableOpacity
                        style={styles.quantityButton}
                        onPress={() => removeFromCart(flavor.id)}
                      >
                        <Text style={styles.quantityButtonText}>−</Text>
                      </TouchableOpacity>

                      <Text style={styles.quantityText}>{amount}</Text>

                      <TouchableOpacity
                        style={styles.quantityButton}
                        onPress={() => addToCart(flavor.id)}
                      >
                        <Text style={styles.quantityButtonText}>+</Text>
                      </TouchableOpacity>
                    </View>
                  )}
                </View>
              </View>
            );
          })}
        </View>

        <View style={styles.cart}>
          <View style={styles.cartDetails}>
            <Text style={styles.cartTitle}>ההזמנה שלי</Text>
            <Text style={styles.cartSummary}>
              {totalItems} פריטים · ₪{totalPrice}
            </Text>
          </View>

          <TouchableOpacity
            style={[
              styles.orderButton,
              totalItems === 0 && styles.orderButtonDisabled,
            ]}
            activeOpacity={0.85}
            onPress={sendWhatsAppOrder}
          >
            <Text style={styles.orderButtonText}>
              שליחת הזמנה ב־WhatsApp
            </Text>
          </TouchableOpacity>
        </View>

        <Text style={styles.footer}>
          ALFAJORSA · Alfajores Premium
        </Text>
      </ScrollView>
    </SafeAreaView>
  );
}

